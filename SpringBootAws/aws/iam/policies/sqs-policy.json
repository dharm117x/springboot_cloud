{
	"Version": "2012-10-17",
	"Statement": [
		{
			"Effect": "Allow",
			"Action": "sqs:ListQueues",
			"Resource": "*"
		},
		{
			"Effect": "Allow",
			"Action": [
				"sqs:CreateQueue",
				"sqs:SendMessage",
				"sqs:ReceiveMessage",
				"sqs:DeleteMessage"
			],
			"Resource": ${jsonencode(queue_arns)}
		}
	]
}