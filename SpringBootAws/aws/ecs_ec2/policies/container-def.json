[
  {
    "name": "springboot-container",
    "memory"   : 512,
    "cpu"      : 512,
    "image"    : "${image_url}",
    "essential": true,
    "environment": [
      { "name": "SERVER_PORT", "value": "9001"},
      { "name": "SPRING_PROFILES_ACTIVE", "value": "dev" },
	  { "name": "SNS_TOPIC_ARN", "value": "${sns_topic_arn}" },
      { "name": "SPRING_DATASOURCE_URL", "value": "jdbc:mysql://${rds_endpoint}:3306/${db_name}" },
	  { "name": "SPRING_DATASOURCE_USERNAME",	"value": "${db_user}"},
	  { "name": "SPRING_DATASOURCE_PASSWORD",	"value": "${db_password}"}
    ],
    "portMappings": [
      { "containerPort": 9001,
        "hostPort": 9001,
        "protocol": "tcp" }
    ],
    "mountPoints": [
    {
      "sourceVolume": "host_logs",
      "containerPath": "/app/logs" 
    }
    ],
      "logConfiguration": {
      "logDriver": "awslogs",
      "options": {
        "awslogs-group": "${log_group_name}",
        "awslogs-region": "${region}",
        "awslogs-stream-prefix": "ecs"
      }
    }   
  }
]